{
  "manifest_version": 3,
  "name": "Google Maps CN Satellite Corrector",
  "version": "1.0.2",
  "description": "Fixes the satellite/label misalignment (GCJ-02 offset) on Google Maps for mainland China. 修正谷歌地图中国大陆卫星图与标注的偏移。",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps*",
        "https://www.google.com.hk/maps*",
        "https://www.google.cn/maps*",
        "https://maps.google.com/*"
      ],
      "js": ["corrector.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "https://www.google.com/maps*",
        "https://www.google.com.hk/maps*",
        "https://www.google.cn/maps*",
        "https://maps.google.com/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
